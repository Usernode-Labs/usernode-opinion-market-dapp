# Opinion Market dapp configuration. Copy to .env and fill in.
#
# Opinion Market is public — no JWT or platform login is required. Wallet
# operations are signed client-side via the bridge (native Usernode channel
# inside the Flutter WebView, QR fallback in a desktop browser). Server-side
# encryption-key publication (publish_pubkeys / reveal_key) is signed by
# SENDER_APP_SECRET_KEY against the sidecar /wallet/send RPC.

# OM dapp's read-only on-chain address. Every OM action (create_survey,
# vote, add_option, set_username, publish_pubkeys, reveal_key) is sent
# *to* this address. Default: the canonical Opinion Market pubkey already
# in use at https://dapps.usernodelabs.org/opinion-market — leaving this
# unset makes the standalone deploy a behavioral duplicate of the
# canonical one (same on-chain history, parallel key publication).
APP_PUBKEY=ut1zkj9p90e0w0hqsnmr70xmzdcvhrj80upajpw67eywszu2g0qknksl3mlms

# Address allowed to issue `create_survey` memos. Leave empty to let
# anyone create a survey. The canonical deploy uses
# ut1ztlalqeecgag03mj5f0k8l9ls06pehgjedhvuautcxy2ewh8tcyqj9alua.
ADMIN_PUBKEY=

# Vote-encryption sender keypair. Distinct from APP_PUBKEY because
# /wallet/send needs UTXOs at the sender, and APP_PUBKEY is a recipient-
# only address. The canonical deploy reuses the lastwin pot keypair
# (ut1y8t50glzr7gm424yxm0tpkkyr8w5q64933sgd0dm3vzzm9ntwruqjncx05) so this
# parallel deploy can do the same — just ensure that keypair has a
# UTXO available for sends.
SENDER_APP_PUBKEY=
SENDER_APP_SECRET_KEY=

# Hex (32-byte) or arbitrary string seed for deriving per-survey ECDH
# encryption key pairs. MUST match every server using the same APP_PUBKEY,
# otherwise votes encrypted against one server can't be decrypted by the
# other. Leave unset to fall back to the dev-seed
# ("dev-seed-do-not-use-in-production"); the canonical deploy currently
# also falls back to that seed, so unset = compatible with the canonical.
# Setting this requires updating *every* co-operating server in lockstep.
VOTE_ENCRYPT_SEED=

# ── Payout pool (automated on-chain settlement) ───────────────────────────
# The Pool wallet holds REAL base-currency that backs market payouts. When a
# market settles (e.g. daily BTC resolves "higher"), the payout bot transfers
# each winner's prize from this wallet straight to their own wallet, then posts
# a `settlement_payout` memo for idempotency/audit/UI. Distinct from APP_PUBKEY
# (recipient-only) and SENDER_APP_PUBKEY (key-publication gas) so payout funds
# are isolated. Leave POOL_APP_PUBKEY unset to fall back to SENDER_APP_PUBKEY.
POOL_APP_PUBKEY=
# Secret half of POOL_APP_PUBKEY. Holds real funds — never logged or returned.
# Leave unset to disable real payouts (bot then only observes / seeds demo).
POOL_APP_SECRET_KEY=
# Virtual-credit → base-currency conversion (onchain = floor(credits * rate)).
# Bounds outflow since bets are zero-value memos. Default 0.01 when unset.
PAYOUT_RATE=0.01
# Floor the pool must not drop below; the bot pays pro-rata when it can't cover
# all owed payouts above this floor. Default 0.
POOL_MIN_BALANCE=0
# Set to 1 on EXACTLY ONE deploy to make it the payout leader. Only the leader
# moves real funds; co-deployed servers sharing APP_PUBKEY stay observe-only.
PAYOUT_LEADER=

# Sidecar node RPC. In social-vibecoding's docker-compose this resolves to
# the usernode-node service via the shared usernode-net network.
NODE_RPC_URL=http://usernode-node:3000

# HTTP port. Matches the platform scaffold's expectation of 3000.
PORT=3000
